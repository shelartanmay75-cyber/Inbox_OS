# ============================================================
# InboxOS Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=sqlite:///./inboxos.db
# For PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/inboxos

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
JWT_SECRET=change-this-to-a-random-32-char-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- AI Providers (choose one or configure all) ---
GEMINI_API_KEY=...
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Active AI provider: gemini | ollama | mock
AI_PROVIDER=gemini

# --- Gmail OAuth ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/auth/callback/gmail

# --- Outlook OAuth ---
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=http://localhost:8000/auth/callback/outlook

# --- WhatsApp / Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_ALLOWED_CHAT_IDS=

# --- App Config ---
APP_NAME=InboxOS
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
