# ─── InboxOS Backend — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git. Only commit this .env.example file.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development                   # Set to 'production' in prod (enables strict TLS for IMAP)

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (local dev):
DATABASE_URL="file:../apps/api/inboxos.db"
# PostgreSQL (production): Uncomment and fill in below, comment out SQLite line above
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/inboxos?schema=public"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_random_64_char_hex_string

# ─── Encryption (P4 — REQUIRED) ───────────────────────────────────────────────
# Used by backend/src/utils/crypto.ts to encrypt all stored OAuth tokens and IMAP passwords.
# MUST be exactly 32 characters. Changing this will invalidate all stored credentials.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=replace_with_exactly_32_characters!!

# ─── Redis (Required for EventBus + Webhook Caching) ──────────────────────────
# Local: redis://localhost:6379/0
# Docker: redis://inboxos-redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ─── Gmail OAuth 2.0 (P4 — Required for Gmail sync) ──────────────────────────
# Steps to get these:
# 1. Go to https://console.cloud.google.com/
# 2. Create project → Enable Gmail API
# 3. Credentials → Create OAuth 2.0 Client ID (Web Application)
# 4. Add authorized redirect URI: http://localhost:8000/api/integrations/gmail/callback
# 5. Copy Client ID and Client Secret below
GMAIL_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REDIRECT_URI=http://localhost:8000/api/integrations/gmail/callback

# ─── AI Features (P2 — Optional, only needed for AI classification) ───────────
# OpenAI
OPENAI_API_KEY=sk-replace_with_your_openai_key
# Google Gemini
GEMINI_API_KEY=replace_with_your_gemini_key
# Which provider to use: 'openai' or 'gemini'
AI_PROVIDER=openai

# ─── Firebase Admin Config ───────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_firebase_project_id.iam.gserviceaccount.com
# For the private key, make sure to replace actual newlines with literal '\n' characters in the .env file.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ..."

