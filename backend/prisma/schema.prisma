datasource db {
  provider = "sqlite"
  url      = "file:../apps/api/inboxos.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  createdAt     DateTime       @default(now())
  emails        Email[]
  settings      UserSettings?
  emailAccounts EmailAccount[]
}

model UserSettings {
  id        String  @id @default(uuid())
  theme     String  @default("dark")
  signature String?
  autoReply Boolean @default(false)

  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Thread {
  id        String   @id @default(uuid())
  summary   String?
  createdAt DateTime @default(now())
  emails    Email[]
}

model Email {
  id          String   @id @default(uuid())
  messageId   String   @unique
  inReplyTo   String?
  sender      String
  recipient   String
  subject     String
  body        String
  status      String   @default("UNREAD")
  category    String?  // Added for email classification
  createdAt   DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model EmailAccount {
  id              String    @id @default(uuid())
  provider        String    // 'gmail', 'outlook', 'imap'
  emailAddress    String
  encryptedTokens String    // Encrypted refresh & access tokens
  syncState       String    @default("connected")
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())

  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, provider, emailAddress])
  @@map("email_accounts")
}
