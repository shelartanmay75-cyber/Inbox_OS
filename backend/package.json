    "@types/imap": "^0.8.43",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.14.9",
    "@types/supertest": "^7.2.0",
    "oxlint": "^1.72.0",
    "prisma": "^5.16.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
