{
  "name": "inboxos-backend",
  "version": "1.0.0",
  "description": "InboxOS Node.js Backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/server.ts",
    "start:prod": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "typecheck": "tsc --noEmit",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "test:classify": "ts-node src/test-classifier.ts",
    "test:summary": "ts-node src/test-summary.ts",
    "test:actions": "ts-node src/test-action-items.ts",
    "test:embeddings": "ts-node src/test-embeddings.ts",
    "worker": "ts-node src/worker.ts",
    "reminder-worker": "ts-node src/reminder-worker.ts",
    "test:worker": "ts-node src/test-worker.ts",
    "test:discord": "ts-node src/test-discord.ts",
    "test:slack": "ts-node src/test-slack.ts",
    "test:gravatar": "ts-node src/test-gravatar.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "node --max-old-space-size=4096 ../node_modules/jest/bin/jest.js --runInBand",
    "test:coverage": "node --max-old-space-size=4096 ../node_modules/jest/bin/jest.js --coverage --runInBand"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@prisma/client": "^5.16.1",
    "@types/handlebars": "^4.0.40",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.2",
    "cheerio": "^1.2.0",
    "chrono-node": "^2.9.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^14.1.0",
    "googleapis": "^173.0.0",
    "handlebars": "^4.7.9",
    "helmet": "^8.0.0",
    "imap": "^0.8.19",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.12",
    "nodemailer": "^9.0.2",
    "openai": "^6.45.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/imap": "^0.8.43",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.19.43",
    "@types/nodemailer": "^6.4.15",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "oxlint": "^1.72.0",
    "prettier": "^3.2.5",
    "prisma": "^5.16.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
