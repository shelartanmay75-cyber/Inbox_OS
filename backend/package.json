  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@prisma/client": "^5.16.1",
    "@types/nodemailer": "^8.0.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^173.0.0",
    "imap": "^0.8.19",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.12",
    "nodemailer": "^9.0.2",
    "openai": "^6.45.0",
    "prom-client": "^15.1.3",
